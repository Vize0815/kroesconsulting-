# Kroes Consulting — Apache config

# ===== Eigene Fehlerseite =====
# Wichtig: ueberschreibt eine evtl. kaputte Server-/Hoster-Default-Fehlerseite
# (z.B. alte WordPress-Theme-Reste), die sonst 500 statt 404 ausliefert.
# /404.html ist reines statisches HTML -> kann nicht selbst 500 werfen.
ErrorDocument 404 /404.html

# ===== Alte WordPress-Pfade: 410 Gone =====
# Google entfernt 410-URLs schneller aus dem Index als 404 und re-crawlt sie nicht.
# Verhindert ausserdem, dass eine kaputte WP-Fehlerseite triggert.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Klassische WordPress-Endpunkte
  RewriteRule ^wp-admin(/.*)?$        - [G,L]
  RewriteRule ^wp-login\.php$         - [G,L]
  RewriteRule ^wp-content(/.*)?$      - [G,L]
  RewriteRule ^wp-includes(/.*)?$     - [G,L]
  RewriteRule ^wp-json(/.*)?$         - [G,L]
  RewriteRule ^wp-cron\.php$          - [G,L]
  RewriteRule ^xmlrpc\.php$           - [G,L]

  # RSS / Atom Feeds der alten WP-Site
  RewriteRule ^feed/?$                - [G,L]
  RewriteRule ^.+/feed/?$             - [G,L]
  RewriteRule ^comments/feed/?$       - [G,L]

  # Author-/Category-/Tag-/Date-Archive
  RewriteRule ^author/.+$             - [G,L]
  RewriteRule ^category/.+$           - [G,L]
  RewriteRule ^tag/.+$                - [G,L]
  RewriteRule ^[0-9]{4}/[0-9]{2}/.+$  - [G,L]

  # ===== 301-Redirects: alte WordPress-Slugs -> neue Seiten =====
  # Sichtbar in Google-Sitelinks (KROES CONSULTING & COACHING / Konfliktcoaching).
  # Behebt 500-Fehler beim Klick auf alte Suchergebnisse.
  RedirectMatch 301 ^/alexander-kroes/?$                                /ueber-uns.html
  RedirectMatch 301 ^/alexander-kroes-2/?$                              /ueber-uns.html
  RedirectMatch 301 ^/ueber-mich/?$                                     /ueber-uns.html
  RedirectMatch 301 ^/about/?$                                          /ueber-uns.html
  RedirectMatch 301 ^/konfliktcoaching(-fuer-[a-z-]+)?/?$                /leistungen.html
  RedirectMatch 301 ^/konfliktmanagement(-fuer-[a-z-]+)?/?$              /leistungen.html
  RedirectMatch 301 ^/angebot(-fuer-[a-z-]+)?/?$                         /leistungen.html
  RedirectMatch 301 ^/consulting(-[a-z-]+)?/?$                           /leistungen.html
  RedirectMatch 301 ^/coaching(-[a-z-]+)?/?$                             /leistungen.html
  RedirectMatch 301 ^/leistung(en)?/?$                                   /leistungen.html
  RedirectMatch 301 ^/services?/?$                                       /leistungen.html
  RedirectMatch 301 ^/home/?$                                            /

  # ===== Extensionless URLs -> .html =====
  # /ueber-uns -> /ueber-uns.html (sofern .html-Datei existiert).
  # Verhindert 500, weil alte WP-URLs ohne Endung in Google-Index sind.
  RewriteCond %{REQUEST_URI} !\.(html|css|js|webp|png|jpe?g|gif|svg|ico|woff2?|xml|txt|pdf|map)$ [NC]
  RewriteCond %{REQUEST_URI} !/$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
  RewriteRule ^(.+?)/?$ /$1.html [R=301,L]
</IfModule>

# XML-Dateien (sitemap.xml) korrekt als application/xml ausliefern,
# damit Google/Bing sie als gueltige Sitemap erkennen.
<IfModule mod_mime.c>
  AddType application/xml .xml
  AddCharset UTF-8 .xml
</IfModule>

# Browser-Caching: lange Cache-Zeiten fuer statische Assets,
# kurze fuer HTML (damit Aenderungen schnell sichtbar werden).
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 month"

  # Bilder: 1 Jahr (aendern sich selten, Dateinamen sind eindeutig)
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"

  # Fonts: 1 Jahr (selbst gehostet, versioniert)
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType application/font-woff2    "access plus 1 year"

  # CSS / JS: 1 Monat
  ExpiresByType text/css                  "access plus 1 month"
  ExpiresByType application/javascript    "access plus 1 month"
  ExpiresByType text/javascript           "access plus 1 month"

  # HTML: 1 Stunde (damit Inhaltsaenderungen rasch sichtbar werden)
  ExpiresByType text/html                 "access plus 1 hour"

  # XML / Sitemap: 1 Tag
  ExpiresByType application/xml           "access plus 1 day"
  ExpiresByType text/xml                  "access plus 1 day"
</IfModule>

# Cache-Control Header zusaetzlich setzen (mod_headers).
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|png|jpe?g|gif|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# Kompression (gzip/deflate) fuer Text-Assets.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/json
</IfModule>

# Brotli falls verfuegbar (Apache 2.4 + mod_brotli).
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html
  AddOutputFilterByType BROTLI_COMPRESS text/css
  AddOutputFilterByType BROTLI_COMPRESS application/javascript
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
  AddOutputFilterByType BROTLI_COMPRESS application/xml
</IfModule>
